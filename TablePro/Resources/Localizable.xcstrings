          }
        }
      }
    },
    "This DROP query will permanently remove database objects. This action cannot be undone." : {
      "localizations" : {
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Truy vấn DROP này sẽ xóa vĩnh viễn các đối tượng cơ sở dữ liệu. Thao tác này không thể hoàn tác."
